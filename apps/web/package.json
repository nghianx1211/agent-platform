{
  "name": "@seta/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Seta web client — React 19, TanStack Router, AI SDK v6, and assistant-ui. The single-page front end for the platform.",
  "scripts": {
    "dev": "vite",
    "generate-routes": "tsr generate",
    "build": "pnpm generate-routes && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "NODE_OPTIONS='--no-experimental-webstorage' vitest run",
    "test:watch": "NODE_OPTIONS='--no-experimental-webstorage' vitest",
    "test:e2e": "playwright test",
    "typecheck": "pnpm generate-routes && tsc -b --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.190",
    "@assistant-ui/react": "^0.14.5",
    "@assistant-ui/react-ai-sdk": "^1.3.26",
    "@assistant-ui/react-markdown": "^0.14.0",
    "@dagrejs/dagre": "^3.0.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@mastra/ai-sdk": "^1.4.3",
    "@seta/planner": "workspace:^",
    "@seta/shared-ui": "workspace:^",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.6",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.25",
    "@tanstack/router-plugin": "^1.168.9",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.188",
    "better-auth": "^1.6.11",
    "date-fns": "^4.2.1",
    "fractional-indexing": "^3.2.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@seta/shared-config": "workspace:^",
    "@tanstack/router-cli": "^1.167.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jest-axe": "^10.0.0",
    "msw": "^2.14.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
}
